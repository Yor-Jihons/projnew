{
    "templates": [
        {
            "id": "name-of-target",
            "description": "サンプル",
            "sourceUrl": "https://github.com/USERNAME/PROJECTNAME.git",
            "sourceType": "git", 
            "defaultBranch": "main", 
            "fileReplacements": [
                {
                    "fileName": "README.md",
                    "placeholder": "{OLD_NAME_IN_TEMPLATE}", 
                    "replacementValue": "{PROJECT_NAME}" 
                }
            ],
            "postCloneActions": [
                "npm install",
                "dotnet restore"
            ]
        }
    ]
}
