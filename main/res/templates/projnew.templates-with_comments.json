// The file must contain a single JSON object with a 'templates' array.
{
    "templates": [
        {
            // [REQUIRED] A unique ID to use in the command (e.g., 'projnew [id] ...').
            "id": "name-of-target",
            // [REQUIRED] A text for the command "list".
            "description": "description for the list",
            // [REQUIRED] The URL to the Git repository.
            "sourceUrl": "https://github.com/USERNAME/PROJECTNAME.git",
            // [OPTIONAL] Type of source. Currently, only 'git' is supported.
            "sourceType": "git",
            // [OPTIONAL] The branch to clone from. Defaults to 'main'.
            "defaultBranch": "main",
            // [OPTIONAL] List of shell commands to execute after cloning/git init.
            "postCloneActions": [
                "npm install",
                "dotnet restore"
            ]
        }
    ]
}
